<h1>{{ title }}</h1>
<p>
	This is a page that showcases Avatar bases that have been setup for use in
	Resonite.
</p>
<p>
	All data on this page is pulled from the <a href="https://wiki.resonite.com/Resonite_ready_avatar_bases">Resonite Wiki</a>, so if you want to see
	more info about a base, or want to add a base, head over there!
</p>

<div id="cards" class="headlineDecoHide"></div>
<script>
	async function loadWikiData() {
		const page = 'Resonite ready avatar bases';
		const url = `https://wiki.resonite.com/api.php?action=parse&page=${page}&prop=text&format=json&origin=*`;
		const res = await fetch(url);
		const data = await res.json();
		const html = data.parse.text['*'];
		const parser = new DOMParser();
		const doc = parser.parseFromString(html, 'text/html');
		const tables = doc.querySelectorAll('table.avatarTable.wikitable');
		tables.forEach((table, ti) => {
			const headers = [...table.querySelectorAll('th')].map((th) =>
				th.textContent.trim(),
			);
			table.querySelectorAll('tr').forEach((row) => {
				const cells = [...row.querySelectorAll('td')].map((td) => {
					const img = td.querySelector('img');
					if (img) {
						// return an object containing all three sizes
						return {
							src: img.src,
							srcset: img.srcset.split(',').map((s) => s.trim()), // ["…120px…", "…180px…", "…240px…"]
							alt: img.alt,
						};
					}
					// Process links in the cell
					const links = td.querySelectorAll('a');
					links.forEach((a) => {
						if (a.getAttribute('href').startsWith('/')) {
							a.setAttribute('href', 'https://wiki.resonite.com' + a.getAttribute('href'));
						}
					});
					return td.innerHTML.trim();
				});
				if (cells.length) {
					const entry = {};
					headers.forEach((header, i) => {
						entry[header] = cells[i];
					});
					console.log('parsed row', entry); // ↪ for debugging
					createCard(entry);
				}
			});
			console.log(`table ${ti} headers:`, headers);
		});
	}
	function createCard(entry) {
		const container = document.getElementById('cards');
		if (!container) {
			return;
		}
		const card = document.createElement('div');
		card.className = 'card';
		let imgHtml = '';
		if (entry.Image && typeof entry.Image === 'object') {
			// Use the largest resolution from srcset
			const largestSrc = entry.Image.srcset[entry.Image.srcset.length - 1].split(' ')[0];
			imgHtml = `<img class="card-image" src="${largestSrc}"
                    srcset="${entry.Image.srcset.join(', ')}"
                    alt="${entry.Image.alt || ''}" onload="checkAspectRatio(this)">`;
		} else {
			// Display a missing image placeholder
			imgHtml = `<img class="card-image square-image" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAwIiBoZWlnaHQ9IjIwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDAlIiBmaWxsPSIjY2NjIi8+PHRleHQgeD0iNTAlIiB5PSI1MCUiIGZvbnQtc2l6ZT0iMTgiIGZpbGw9IiM5OTkiIHRleHQtYW5jaG9yPSJtaWRkbGUiIGR5PSIuM2VtIj5ObyBJbWFnZTwvdGV4dD48L3N2Zz4="
                    alt="No Image Available">`;
		}
		const licenseHtml = entry.License ? `<div class="cardLicense">${entry.License}</div>` : '';
		card.innerHTML = `
    <div class="cardImage">
      ${imgHtml}
      ${licenseHtml}
    </div>
    <div class="cardContent">
      <h2 class="h5">${entry['Name'] || 'Unknown'}</h2>
      <p>Artist: ${entry.Artist || '-'}</p>
    </div>
  `;
		container.appendChild(card);
	}
	function checkAspectRatio(img) {
		const ratio = img.naturalWidth / img.naturalHeight;
		if (Math.abs(ratio - 1) < 0.1) {
			img.classList.add('square-image');
		}
	}
	document.addEventListener('DOMContentLoaded', loadWikiData);
</script>
